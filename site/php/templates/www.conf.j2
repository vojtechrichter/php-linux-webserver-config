[www]
user  = www-data
group = www-data

listen       = /run/php/php{{ php_version }}-fpm.sock
listen.owner = www-data
listen.group = www-data
listen.mode  = 0660

pm                        = dynamic
pm.max_children           = 20
pm.start_servers          = 5
pm.min_spare_servers      = 3
pm.max_spare_servers      = 10
pm.max_requests           = 500

access.log                = /var/log/php{{ php_version }}-fpm-access.log
slowlog                   = /var/log/php{{ php_version }}-fpm-slow.log
request_slowlog_timeout   = 5s
request_terminate_timeout = 60s

security.limit_extensions = .php
clear_env                 = yes

env[PATH]   = /usr/local/bin:/usr/bin:/bin
env[TMPDIR] = /tmp
env[TMP]    = /tmp

php_admin_value[error_log]           = /var/log/php{{ php_version }}-fpm-errors.log
php_admin_flag[log_errors]           = on
php_admin_value[memory_limit]        = 256M
php_admin_value[upload_max_filesize] = 64M
php_admin_value[post_max_size]       = 64M
php_admin_value[session.save_path]   = /var/lib/php/sessions
php_flag[display_errors]             = off